    {
      "_template": "tabbedContent",
      "heading": "Understanding the EHCP Assessment Process",
      "tabs": [
        {
          "label": "Before the Assessment",
          "content": {
            "type": "root",
            "children": [
              {
                "type": "p",
                "children": [
                  {
                    "type": "text",
                    "text": "Preparation is key. Before the EP arrives:"
                  }
                ]
              },
              {
                "type": "ul",
                "children": [
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Schools and parents should gather initial observations (how does the child struggle?)"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Previous assessments, reports, or diagnoses should be available"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Key people involved (teachers, parents, other professionals) should be ready to speak with the EP"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "The referral form provided by the LA should be completed fully"
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "p",
                "children": [
                  {
                    "type": "text",
                    "text": "Our referral form gathers this information in advance, so the EP arrives fully briefed. Less time wasted getting up to speed, more time focused on assessment."
                  }
                ]
              }
            ]
          }
        },
        {
          "label": "During the Assessment",
          "content": {
            "type": "root",
            "children": [
              {
                "type": "p",
                "children": [
                  {
                    "type": "text",
                    "text": "A typical EHCP assessment includes:"
                  }
                ]
              },
              {
                "type": "ul",
                "children": [
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Interview with parent/carer (background, development, home context)"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Interview with teacher/SENCO (school presentation, observed difficulties, strategies tried)"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Direct assessment: cognitive testing, attainment testing, observation, functional assessment"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Review of previous assessments or diagnoses"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Structured interviews exploring emotional, social, and behavioural factors"
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "p",
                "children": [
                  {
                    "type": "text",
                    "text": "The EP will be warm, professional, and sensitive to the child's experience. Assessment may be split across multiple visits as needed."
                  }
                ]
              }
            ]
          }
        },
        {
          "label": "After the Assessment",
          "content": {
            "type": "root",
            "children": [
              {
                "type": "p",
                "children": [
                  {
                    "type": "text",
                    "text": "Once the EP completes the assessment, we:"
                  }
                ]
              },
              {
                "type": "ul",
                "children": [
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Analyse findings and write the report (typically 2 weeks)"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Quality-check the report to ensure all statutory questions are answered"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Deliver the report to you (school and/or LA)"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Offer to brief the school if helpful"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Make the EP available for EHCP panel meetings or follow-up if needed"
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "p",
                "children": [
                  {
                    "type": "text",
                    "text": "The report is written for the LA, schools, parents, and other professionals. Language is clear, not jargony."
                  }
                ]
              }
            ]
          }
        },
        {
          "label": "Statutory Questions the Assessment Must Address",
          "content": {
            "type": "root",
            "children": [
              {
                "type": "p",
                "children": [
                  {
                    "type": "text",
                    "text": "LA officers will ask the EP about:"
                  }
                ]
              },
              {
                "type": "ul",
                "children": [
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "The child's cognitive ability and attainment"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Specific learning difficulties or disabilities"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Social, emotional, and mental health needs"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Communication and interaction abilities"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "Sensory or physical needs"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "How these needs affect the child's learning"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "li",
                    "children": [
                      {
                        "type": "lic",
                        "children": [
                          {
                            "type": "text",
                            "text": "What support would help the child thrive"
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "p",
                "children": [
                  {
                    "type": "text",
                    "text": "A quality assessment report answers all these questions with evidence."
                  }
                ]
              }
            ]
          }
        }
      ]
    },

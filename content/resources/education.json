    {
      "_template": "faqAccordion",
      "heading": "Education Resources FAQs",
      "faqs": [
        {
          "question": "Can I download all these resources at once?",
          "answer": "You can download individual guides via the tabs above. For a complete package of all education resources, email resources@psychologydirect.co.uk. We'll send a ZIP file."
        },
        {
          "question": "Are these guides updated when regulations change?",
          "answer": "Yes. We update guides annually and immediately when SEND Code, KCSIE, or other regulations change. Subscribe to our newsletter to stay notified."
        },
        {
          "question": "Can I customise templates for my school or LA?",
          "answer": "Yes. Templates are free to customise for internal use. If you need significant modifications for your specific process, contact us. We may be able to help."
        },
        {
          "question": "Who has written these guides?",
          "answer": "All guides are written by experienced Educational Psychologists and senior SEND professionals with 15+ years' experience working with schools and local authorities."
        },
        {
          "question": "Can I share these with other schools or LAs?",
          "answer": "Yes. Share freely with colleagues in your cluster, network, or region. We ask that you credit Psychology Direct, but we don't require permission."
        },
        {
          "question": "What's your guidance on a specific topic not listed?",
          "answer": "Email resources@psychologydirect.co.uk with your question. We create new guides based on professional needs and may add it to the library."
        },
        {
          "question": "Are these resources suitable for all UK regions?",
          "answer": "Most resources are UK-wide. Some sections reference England and Wales procedures. If you need Scotland or Northern Ireland-specific guidance, contact us directly."
        }
      ]
    },

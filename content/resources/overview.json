      "_template": "faqAccordion",
      "heading": "Common Questions",
      "faqs": [
        {
          "question": "Are these resources free?",
          "answer": "Yes, completely free. Download guides, templates, and case studies without registration. We believe in sharing expertise."
        },
        {
          "question": "Can I share these with colleagues?",
          "answer": "Yes. Share with your team or organisation. We ask that you credit us, but we don't require permission."
        },
        {
          "question": "How often are resources updated?",
          "answer": "We update quarterly and add new ones monthly. We revise legal and compliance guidance whenever laws change, such as Legal Aid fees or SEND Code updates."
        },
        {
          "question": "I need a resource on a specific topic. Do you have it?",
          "answer": "Check the Legal, Education, or Professional tabs above. Can't find it? Email resources@psychologydirect.co.uk and we'll create it or point you to what you need."
        },
        {
          "question": "Can I use these templates with my organisation?",
          "answer": "Yes, templates are free for organisational use. If you need customisation, contact us and we may be able to help."
        },
        {
          "question": "Do you have resources for non-lawyers and non-educators?",
          "answer": "Yes. We have guides for independent practitioners, case managers, and related professionals. See the For Professionals tab."
        },
        {
          "question": "How do I get updates when new resources are published?",
          "answer": "Sign up for our monthly newsletter. We'll email you summaries of new guides, templates, and case studies."
        }
      ]

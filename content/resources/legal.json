    {
      "_template": "faqAccordion",
      "heading": "Legal Resources FAQs",
      "faqs": [
        {
          "question": "Can I download all these resources at once?",
          "answer": "You can download individual guides via the tabs above. For a complete package of all legal resources, email resources@psychologydirect.co.uk. We'll send a ZIP file."
        },
        {
          "question": "Are these resources updated when laws change?",
          "answer": "Yes. We update guides quarterly and immediately when relevant laws change, including Legal Aid updates, new CPR rules, and SEND Code changes. Subscribe to our newsletter to get notified."
        },
        {
          "question": "Can I modify templates for my firm?",
          "answer": "Yes. Templates are free to customise for internal use. If you need significant modifications for your process, contact us. We may be able to help."
        },
        {
          "question": "Are these suitable for all legal jurisdictions?",
          "answer": "Most resources cover England and Wales family, criminal, and civil law. Immigration guidance is UK-wide. If you need guidance for Scotland or Northern Ireland, contact us directly."
        },
        {
          "question": "Can I share these with clients or other firms?",
          "answer": "Yes. Share freely with colleagues and clients. We ask that you credit Psychology Direct, but we don't require permission."
        },
        {
          "question": "I need a guide on a specific topic not listed. Can you create one?",
          "answer": "Email resources@psychologydirect.co.uk with your request. We create new guides based on professional needs and may add it to the library."
        }
      ]
